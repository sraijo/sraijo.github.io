-- MULTIPLIER CATEGORY LOGIC
----------------------------------------------------------------

local function getColorCategory(mult)
    if mult >= 4 then return 6
    elseif mult >= 3 then return 5
    elseif mult > 2.5 then return 4
    elseif mult >= 2 then return 3
    elseif mult >= 1.5 then return 2
    elseif mult > 1 then return 1
    else return 0 end
end

local multiplierOptions = {1.5, 2.0, 2.51, 3.0, 4.0}
local multiplierIndex = 1
local selectedMultiplier = multiplierOptions[multiplierIndex]

local function getSelectedCategory()
    return getColorCategory(selectedMultiplier)
end

local function getMultiplierColor(mult)
    if mult>=4 then return Color3.fromRGB(255,105,180)
    elseif mult>=3 then return Color3.fromRGB(160,32,240)
    elseif mult>2.5 then return Color3.fromRGB(255,0,0)
    elseif mult>=2 then return Color3.fromRGB(255,255,0)
    elseif mult>=1.5 then return Color3.fromRGB(0,200,255)
    elseif mult>1 then return Color3.fromRGB(0,255,0)
    else return Color3.new(1,1,1) end
end

