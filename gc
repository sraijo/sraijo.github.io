----------------------------------------------------------------
-- COORDINATE BEAM
----------------------------------------------------------------

local function showCoordinateBeam(position, speciesName)
    if coordBeam then coordBeam:Destroy() coordBeam = nil end
    if coordAttachment then coordAttachment:Destroy() coordAttachment = nil end

    local a1 = Instance.new("Attachment", root)

    coordAttachment = Instance.new("Attachment", workspace.Terrain)
    coordAttachment.WorldPosition = position

    coordBeam = Instance.new("Beam", workspace)
    coordBeam.Attachment0 = a1
    coordBeam.Attachment1 = coordAttachment
    coordBeam.Width0 = 0.25
    coordBeam.Width1 = 0.25
    coordBeam.FaceCamera = true
    coordBeam.Color = ColorSequence.new(traceColors[speciesName] or Color3.new(0,1,0))
end

----------------------------------------------------------------
-- START / PAUSE / RESUME / SPEED / MULTIPLIER
----------------------------------------------------------------

local donutStartDelay = 10

startButton.MouseButton1Click:Connect(function()
    donutScanning = false
    donutPaused = true
    donutCurrentRadiusIndex = 1
    donutAngle = 0
    pauseReason.Text = "Loading..."
    pauseDetail.Text = ""
    lastDetectedPosition = nil

    if coordBeam then coordBeam:Destroy() coordBeam = nil end
    if coordAttachment then coordAttachment:Destroy() coordAttachment = nil end

    local activeRadii = getActiveRadii()
    local firstRadius = activeRadii[1]
    local startPos = Vector3.new(firstRadius, donutFlyHeight, 0)
    root.CFrame = CFrame.new(startPos)

    local hum = character:FindFirstChildOfClass("Humanoid")
    if hum then hum:Move(Vector3.new(0,0,0), true) end

    task.wait(2)

    local bp = Instance.new("BodyPosition")
    bp.MaxForce = Vector3.new(1e9, 1e9, 1e9)
    bp.D = 1000
    bp.P = 50000
    bp.Position = startPos
    bp.Parent = root

    task.delay(donutStartDelay, function()
        donutPaused = false
        donutScanning = true
        pauseReason.Text = "Scanning..."
        pauseDetail.Text = ""
        bp:Destroy()
    end)
end)

pauseButton.MouseButton1Click:Connect(function()
    if donutScanning then
        donutPaused = true
        pauseReason.Text = "Paused..."
    end
end)

continueButton.MouseButton1Click:Connect(function()
    if donutScanning then
        donutPaused = false
        pauseReason.Text = "Scanning..."
        pauseDetail.Text = ""

        donutAngle = donutAngle - rewindAmount
        if donutAngle < 0 then donutAngle = 0 end

        lastDetectedPosition = nil
        if coordBeam then coordBeam:Destroy() coordBeam = nil end
        if coordAttachment then coordAttachment:Destroy() coordAttachment = nil end
    end
end)

local speeds = {0.005, 0.01, 0.013, 0.02}
local speedIndex = 2

speedButton.MouseButton1Click:Connect(function()
