local baseHpLookup = {
    Dodo=25,Compsognathus=40,Gallimimus=150,Bronto=1000,
    Parasaurus=150,Dilophosaurus=150,
    Triceratops=1000,Stegosaurus=1800,Raptor=300,Ankylosaurus=1500,
    Carnotaurus=1400,Grizzly=800,Tiger=400,Trex=3500,

    Ichyosaurus=1500,
    Plesiosaurus=1500,
    Mosasaur=2000
}

local traceColors = {
    Dodo=Color3.fromRGB(128,0,0),
    Compsognathus=Color3.fromRGB(255,105,180),
    Gallimimus=Color3.fromRGB(0,150,255),
    Bronto=Color3.fromRGB(255,255,255),
    Parasaurus=Color3.fromRGB(0,0,0),
    Dilophosaurus=Color3.fromRGB(255,165,0),
    Triceratops=Color3.fromRGB(128,0,128),
    Stegosaurus=Color3.fromRGB(75,0,130),
    Raptor=Color3.fromRGB(255,0,0),
    Ankylosaurus=Color3.fromRGB(0,255,0),
    Carnotaurus=Color3.fromRGB(255,20,147),
    Grizzly=Color3.fromRGB(0,0,139),
    Tiger=Color3.fromRGB(255,140,0),
    Trex=Color3.fromRGB(255,255,255),

    Ichyosaurus=Color3.fromRGB(0,255,80),
    Plesiosaurus=Color3.fromRGB(200,0,255),
    Mosasaur=Color3.fromRGB(180,0,40)
}

local function getHpColor(name,maxHp)
    local base = baseHpLookup[name] or maxHp
    local multiplier = maxHp/base
    if multiplier>=4 then return Color3.fromRGB(255,105,180)
    elseif multiplier>=3 then return Color3.fromRGB(160,32,240)
    elseif multiplier>2.5 then return Color3.fromRGB(255,0,0)
    elseif multiplier>=2 then return Color3.fromRGB(255,255,0)
    elseif multiplier>=1.5 then return Color3.fromRGB(0,200,255)
    elseif multiplier>1 then return Color3.fromRGB(0,255,0)
    else return Color3.new(1,1,1) end
end

----------------------------------------------------------------
-- TRACE FUNCTIONS
----------------------------------------------------------------

local function createTrace(mob,name)
    local char = player.Character
    if not char then return end
    local rootPart = char:FindFirstChild("HumanoidRootPart")
    local mobRoot = mob:FindFirstChild("HumanoidRootPart") or mob:FindFirstChild("Head")
    if not rootPart or not mobRoot then return end

    local traceName = "TraceLine_"..mob.Name
    local existing = workspace:FindFirstChild(traceName)
    if existing then existing:Destroy() end

    local a1 = Instance.new("Attachment", rootPart)
    local a2 = Instance.new("Attachment", mobRoot)

    local beam = Instance.new("Beam", workspace)
    beam.Name = traceName
    beam.Attachment0 = a1
    beam.Attachment1 = a2
    beam.FaceCamera = true
    beam.Width0 = 0.2
    beam.Width1 = 0.2
    beam.Color = ColorSequence.new(traceColors[name] or Color3.fromRGB(0,0,255))
end

local function toggleTraceToMob(mob,name)
    local traceName = "TraceLine_"..mob.Name
    local existing = workspace:FindFirstChild(traceName)
    if existing then
        existing:Destroy()
    else
        createTrace(mob,name)
    end
end

----------------------------------------------------------------
-- GET ANIMALS (FILTERED)
----------------------------------------------------------------

local function getAnimals()
    local grouped = {}
    local animals = {}

    for _,mob in pairs(mobsFolder:GetChildren()) do
        local h = mob:FindFirstChildOfClass("Humanoid")
        if h then
            local name = h.DisplayName ~= "" and h.DisplayName or mob:GetAttribute("AnimalName") or "Unknown"

            if not excluded[name] then
                grouped[name] = grouped[name] or {}
                table.insert(grouped[name], {
                    mob = mob,
                    name = name,
                    hp = h.Health,
                    maxHp = h.MaxHealth
                })
            end
        end
    end

    for _,list in pairs(grouped) do
        table.sort(list, function(a,b)
            return a.maxHp > b.maxHp
        end)

        for i = 1, math.min(animalLimit, #list) do
            table.insert(animals, list[i])
        end
    end

    table.sort(animals, function(a,b)
        return a.maxHp > b.maxHp
    end)

    return animals
end

----------------------------------------------------------------
-- BUILD LIST
----------------------------------------------------------------

function buildList()
    local currentMobs = {}
    for _,d in ipairs(getAnimals()) do
        currentMobs[d.mob] = true
    end

    for _,beam in pairs(workspace:GetChildren()) do
        if beam:IsA("Beam") and beam.Name:find("TraceLine_") then
            local mobName = beam.Name:gsub("TraceLine_","")
            local mob = mobsFolder:FindFirstChild(mobName)
            if not mob or not currentMobs[mob] then
                beam:Destroy()
            end
        end
    end

    for _,c in pairs(scroll:GetChildren()) do
        c:Destroy()
    end

    buttons = {}
    local y = 0

    for _,d in ipairs(getAnimals()) do
        local multiplier = d.maxHp / (baseHpLookup[d.name] or d.maxHp)

        local container = Instance.new("Frame", scroll)
        container.Size = UDim2.new(1,-10,0,18)
        container.Position = UDim2.new(0,5,0,y)
        container.BackgroundTransparency = 1

        local colorBox = Instance.new("Frame", container)
        colorBox.Size = UDim2.new(0,12,0,12)
        colorBox.Position = UDim2.new(0,0,0,3)
        colorBox.BackgroundColor3 = traceColors[d.name] or Color3.fromRGB(255,255,255)

        local b = Instance.new("TextButton", container)
        b.Size = UDim2.new(1,-20,1,0)
        b.Position = UDim2.new(0,16,0,0)
        b.BackgroundTransparency = 1
        b.Font = Enum.Font.SourceSans
        b.TextSize = 12
        b.Text = string.format("%s (x%.2f) - HP: %d/%d",
            d.name, multiplier, math.floor(d.hp), math.floor(d.maxHp))
        b.TextColor3 = getHpColor(d.name, d.maxHp)

        b.MouseButton1Click:Connect(function()
            toggleTraceToMob(d.mob, d.name)
        end)

        buttons[d.mob] = container
        y = y + 20
    end

    scroll.CanvasSize = UDim2.new(0,0,0,y)

    if tracesOn then
        for _,d in ipairs(getAnimals()) do
            local traceName = "TraceLine_"..d.mob.Name
            if not workspace:FindFirstChild(traceName) then
                createTrace(d.mob, d.name)
            end
        end
    end
end

----------------------------------------------------------------
-- UPDATE LIST
----------------------------------------------------------------

local function updateList()
    local y = 0

    for _,d in ipairs(getAnimals()) do
        local multiplier = d.maxHp / (baseHpLookup[d.name] or d.maxHp)
        local container = buttons[d.mob]

        if container then
            container.Position = UDim2.new(0,5,0,y)

            local b = container:FindFirstChildOfClass("TextButton")
            local colorBox = container:FindFirstChildOfClass("Frame")

            if b then
                b.Text = string.format("%s (x%.2f) - HP: %d/%d",
                    d.name, multiplier, math.floor(d.hp), math.floor(d.maxHp))
                b.TextColor3 = getHpColor(d.name, d.maxHp)
            end

            if colorBox then
                colorBox.BackgroundColor3 = traceColors[d.name] or Color3.fromRGB(255,255,255)
            end

            y = y + 20
        else
            buildList()
            return
        end
    end

    scroll.CanvasSize = UDim2.new(0,0,0,y)

    if tracesOn then
        for _,d in ipairs(getAnimals()) do
            local traceName = "TraceLine_"..d.mob.Name
            if not workspace:FindFirstChild(traceName) then
                createTrace(d.mob, d.name)
            end
        end
    end
end

