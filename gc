end)

----------------------------------------------------------------
-- MAIN HEARTBEAT: TIMER + LIGHTING + LIST + GLOBAL DETECTION + ORBIT
----------------------------------------------------------------

RunService.Heartbeat:Connect(function(dt)
    ----------------------------------------------------------------
    -- TIMER
    ----------------------------------------------------------------
    local elapsed = workspace.DistributedGameTime
    local remaining = math.max(totalDuration - elapsed, 0)
    local minutes = math.floor(remaining / 60)
    local seconds = math.floor(remaining % 60)
    timerLabel.Text = string.format("%02d:%02d", minutes, seconds)

    if remaining <= 0 then
        returnButton.Visible = true
    end

    ----------------------------------------------------------------
    -- LIGHTING TOGGLES
    ----------------------------------------------------------------
    if _G.FullBrightEnabled then
        Lighting.Brightness = 1
        Lighting.ClockTime = 12
        Lighting.FogEnd = 786543
        Lighting.GlobalShadows = false
        Lighting.Ambient = Color3.fromRGB(178,178,178)
    elseif _G.NormalLightingSettings then
        Lighting.Brightness = _G.NormalLightingSettings.Brightness
        Lighting.ClockTime = _G.NormalLightingSettings.ClockTime
        Lighting.FogEnd = _G.NormalLightingSettings.FogEnd
        Lighting.GlobalShadows = _G.NormalLightingSettings.GlobalShadows
        Lighting.Ambient = _G.NormalLightingSettings.Ambient
    end

    if _G.NoFogEnabled then
        Lighting.FogEnd = 100000
        for _,v in ipairs(Lighting:GetDescendants()) do
            if v:IsA("Atmosphere") then
                v.Density = 0
            end
        end
    end

    ----------------------------------------------------------------
    -- LIST UPDATES
    ----------------------------------------------------------------
    updateList()

    ----------------------------------------------------------------
    -- SCANNER STATE CHECK
    ----------------------------------------------------------------
    if not donutScanning or donutPaused or player.GameplayPaused then
        return
    end

    pauseReason.Text = "Scanning..."
    pauseDetail.Text = ""

    ----------------------------------------------------------------
    -- GLOBAL DETECTION (NO RING LIMIT)
    ----------------------------------------------------------------
    local animals = getAnimals()
    local selectedCategory = getSelectedCategory()

    for _,d in ipairs(animals) do
        local base = baseHpLookup[d.name] or d.maxHp
        local mult = d.maxHp / base
        local fixedMult = math.floor(mult * 100 + 0.5) / 100
        local mobCategory = getColorCategory(fixedMult)

        if mobCategory >= selectedCategory then
            donutPaused = true
            lastDetectedTime = tick()

            local mobRoot = d.mob:FindFirstChild("HumanoidRootPart") or d.mob:FindFirstChild("Head")
            if mobRoot then
                lastDetectedPosition = mobRoot.Position
                showCoordinateBeam(lastDetectedPosition, d.name)
            end

            pauseReason.Text = string.format("Paused. Found %s x%.2f", d.name, fixedMult)
            pauseDetail.Text = string.format("HP: %d/%d", math.floor(d.hp), math.floor(d.maxHp))
            return
        end
    end

    ----------------------------------------------------------------
    -- ORBIT MOVEMENT (IF NOTHING FOUND)
    ----------------------------------------------------------------
    local radii = getActiveRadii()
    if #radii == 0 then return end

    local radius = radii[donutCurrentRadiusIndex]
    donutAngle = donutAngle + donutOrbitSpeed

    local x = math.cos(donutAngle) * radius
    local z = math.sin(donutAngle) * radius
    root.CFrame = CFrame.new(x, donutFlyHeight, z)

    if donutAngle >= math.pi * 2 then
        donutAngle = 0
        donutCurrentRadiusIndex = donutCurrentRadiusIndex + 1
        if donutCurrentRadiusIndex > #radii then
            donutCurrentRadiusIndex = 1
        end
    end
end)

